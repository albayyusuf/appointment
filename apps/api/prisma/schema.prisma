// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerticalType {
  BEAUTY
  HEALTH
}

enum UserStatus {
  ACTIVE
  INVITED
  SUSPENDED
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum BillingInterval {
  MONTHLY
  YEARLY
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  PAST_DUE
  CANCELED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

model Tenant {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  customDomain   String?       @unique
  vertical       VerticalType
  defaultCurrency String       @default("TRY")
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  branches       Branch[]
  users          User[]
  staffProfiles  StaffProfile[]
  roles          Role[]
  userRoles      UserRole[]
  customers      Customer[]
  serviceCats    ServiceCategory[]
  services       Service[]
  schedules      Schedule[]
  appointments   Appointment[]
  statusHistory  AppointmentStatusHistory[]
  auditLogs      AuditLog[]
  subscriptions  Subscription[]
  ledgerEntries  LedgerEntry[]
}

model PlatformUser {
  id           String   @id @default(cuid())
  email        String   @unique
  fullName     String
  passwordHash String
  isSuperAdmin Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Plan {
  id                String          @id @default(cuid())
  code              String          @unique
  name              String
  description       String?
  priceAmount       Decimal         @db.Decimal(12, 2)
  currency          String          @default("TRY")
  interval          BillingInterval
  trialDays         Int             @default(14)
  maxBranches       Int             @default(1)
  maxStaff          Int             @default(5)
  maxAppointmentsMo Int             @default(500)
  isActive          Boolean         @default(true)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  subscriptions     Subscription[]
}

model Subscription {
  id                   String             @id @default(cuid())
  tenantId             String
  planId               String
  status               SubscriptionStatus @default(TRIAL)
  startsAt             DateTime           @default(now())
  endsAt               DateTime?
  trialEndsAt          DateTime?
  nextBillingAt        DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  tenant               Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  plan                 Plan               @relation(fields: [planId], references: [id], onDelete: Restrict)
  payments             Payment[]

  @@index([tenantId, status])
  @@index([planId, status])
}

model Payment {
  id               String        @id @default(cuid())
  subscriptionId   String
  amount           Decimal       @db.Decimal(12, 2)
  currency         String        @default("TRY")
  status           PaymentStatus @default(PENDING)
  provider         String
  providerRef      String?
  paidAt           DateTime?
  failedAt         DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  subscription     Subscription  @relation(fields: [subscriptionId], references: [id], onDelete: Restrict)

  @@index([subscriptionId, status, createdAt])
}

model LedgerEntry {
  id            String   @id @default(cuid())
  tenantId      String
  appointmentId String?
  type          String
  amount        Decimal  @db.Decimal(12, 2)
  currency      String   @default("TRY")
  description   String?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointment   Appointment? @relation(fields: [appointmentId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
}

model Branch {
  id             String        @id @default(cuid())
  tenantId       String
  parentBranchId String?
  name           String
  code           String
  phone          String?
  addressLine    String?
  city           String?
  country        String?
  isActive       Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  parentBranch   Branch?       @relation("BranchHierarchy", fields: [parentBranchId], references: [id], onDelete: Restrict)
  childBranches  Branch[]      @relation("BranchHierarchy")
  users          User[]
  services       Service[]
  schedules      Schedule[]
  appointments   Appointment[]

  @@unique([tenantId, code])
  @@index([tenantId, name])
  @@index([tenantId, parentBranchId])
}

model User {
  id             String        @id @default(cuid())
  tenantId       String
  branchId       String?
  email          String
  passwordHash   String
  fullName       String
  status         UserStatus    @default(INVITED)
  isStaff        Boolean       @default(false)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?
  tenant         Tenant        @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch         Branch?       @relation(fields: [branchId], references: [id], onDelete: SetNull)
  staffProfile   StaffProfile?
  userRoles      UserRole[]
  schedules      Schedule[]
  appointments   Appointment[] @relation("AppointmentStaff")
  createdAppts   Appointment[] @relation("AppointmentCreatedBy")
  statusHistory  AppointmentStatusHistory[]
  auditLogs      AuditLog[]

  @@unique([tenantId, email])
  @@index([tenantId, branchId])
}

model StaffProfile {
  id                String    @id @default(cuid())
  tenantId          String
  userId            String    @unique
  externalRef       String?
  specialty         String?
  commissionRatePct Decimal?  @db.Decimal(5, 2)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  tenant            Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, externalRef])
  @@index([tenantId, specialty])
}

model Role {
  id          String     @id @default(cuid())
  tenantId    String
  code        String
  name        String
  description String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  tenant      Tenant     @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  userRoles   UserRole[]

  @@unique([tenantId, code])
}

model UserRole {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String
  roleId     String
  createdAt  DateTime @default(now())
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId, roleId])
}

model Customer {
  id          String      @id @default(cuid())
  tenantId    String
  fullName    String
  phone       String?
  email       String?
  birthDate   DateTime?
  notes       String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointments Appointment[]

  @@index([tenantId, fullName])
  @@index([tenantId, phone])
}

model ServiceCategory {
  id          String      @id @default(cuid())
  tenantId    String
  name        String
  vertical    VerticalType
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  services    Service[]

  @@unique([tenantId, name, vertical])
}

model Service {
  id             String      @id @default(cuid())
  tenantId       String
  branchId       String
  categoryId     String
  name           String
  durationMin    Int
  priceAmount    Decimal     @db.Decimal(12, 2)
  currency       String      @default("TRY")
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  category       ServiceCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  appointments   Appointment[]

  @@index([tenantId, branchId, isActive])
  @@index([tenantId, categoryId])
}

model Schedule {
  id             String      @id @default(cuid())
  tenantId       String
  branchId       String
  staffUserId    String
  startsAt       DateTime
  endsAt         DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  tenant         Tenant      @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch         Branch      @relation(fields: [branchId], references: [id], onDelete: Restrict)
  staffUser      User        @relation(fields: [staffUserId], references: [id], onDelete: Cascade)

  @@index([tenantId, branchId, startsAt, endsAt])
  @@index([tenantId, staffUserId, startsAt, endsAt])
}

model Appointment {
  id              String                   @id @default(cuid())
  tenantId        String
  branchId        String
  customerId      String
  serviceId       String
  staffUserId     String
  createdByUserId String
  startsAt        DateTime
  endsAt          DateTime
  status          AppointmentStatus        @default(PENDING)
  notes           String?
  createdAt       DateTime                 @default(now())
  updatedAt       DateTime                 @updatedAt
  cancelledAt     DateTime?
  tenant          Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  branch          Branch                   @relation(fields: [branchId], references: [id], onDelete: Restrict)
  customer        Customer                 @relation(fields: [customerId], references: [id], onDelete: Restrict)
  service         Service                  @relation(fields: [serviceId], references: [id], onDelete: Restrict)
  staffUser       User                     @relation("AppointmentStaff", fields: [staffUserId], references: [id], onDelete: Restrict)
  createdByUser   User                     @relation("AppointmentCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  statusHistory   AppointmentStatusHistory[]
  ledgerEntries   LedgerEntry[]

  @@index([tenantId, branchId, startsAt])
  @@index([tenantId, staffUserId, startsAt, endsAt])
  @@index([tenantId, customerId, startsAt])
}

model AppointmentStatusHistory {
  id             String            @id @default(cuid())
  tenantId       String
  appointmentId  String
  changedByUserId String
  fromStatus     AppointmentStatus?
  toStatus       AppointmentStatus
  changedAt      DateTime          @default(now())
  reason         String?
  tenant         Tenant            @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  appointment    Appointment       @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  changedByUser  User              @relation(fields: [changedByUserId], references: [id], onDelete: Restrict)

  @@index([tenantId, appointmentId, changedAt])
}

model AuditLog {
  id            String   @id @default(cuid())
  tenantId      String
  actorUserId   String?
  entityType    String
  entityId      String
  action        String
  metadata      Json?
  createdAt     DateTime @default(now())
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorUser     User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([tenantId, entityType, entityId, createdAt])
}
